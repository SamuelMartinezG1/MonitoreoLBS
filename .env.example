# ============================================================================
# LBS Monitor — variables de entorno
# ============================================================================
# Copia este archivo a `.env` y ajusta los valores. NUNCA lo subas al repo.

# --- Identidad del stack ----------------------------------------------------
# Se usa como prefijo de containers/volúmenes (lbs-db, lbs-portal, …).
PROJECT_NAME=lbs

# --- App --------------------------------------------------------------------
# SECRET_KEY es obligatoria (firma cookies de sesión).
# Genera una con: python -c "import secrets;print(secrets.token_urlsafe(48))"
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria

APP_PORT=5000
LOG_LEVEL=INFO

# --- Polling ----------------------------------------------------------------
# Cada cuánto el MonitoringService dispara un ciclo SNMP (segundos).
POLL_INTERVAL=2

# Tope del ciclo Modbus (segundos). El loop dormirá lo que falte de este
# presupuesto si los polls terminan antes.
MODBUS_POLL_INTERVAL=2

# Workers concurrentes para Modbus. A 150 UPS: 32 ~> ciclo ~15 s. Sube si
# tus UPS están repartidos en muchas redes; baja si ZeroTier se satura.
MODBUS_POLL_WORKERS=32

# --- Sample rates para PostgreSQL -------------------------------------------
# Cada cuánto se inserta una fila a ups_metrics (EAV). 30 s es el sweet spot
# para 150 UPS sin necesitar particionado.
METRICS_SAMPLE_INTERVAL_S=30

# Cada cuánto se inserta un punto a ups_chart_history (para gráficas).
HISTORY_SAMPLE_INTERVAL_S=30

# Submuestreo de los bloques caros de Modbus (estados / sensores / módulos).
MODBUS_STATUS_INTERVAL_S=6
MODBUS_ENV_INTERVAL_S=30
MODBUS_MODULES_INTERVAL_S=10

# TTL del cliente SNMP cacheado por dispositivo (recrea el SnmpEngine cada N s).
SNMP_CLIENT_TTL_S=300

# Timeouts de lectura — súbelos si los UPS van por enlace lento/intermitente
# (p.ej. módem SIM o ZeroTier con relay). No afecta el intervalo de muestreo.
SNMP_TIMEOUT_S=5       # segundos de espera por GET SNMP
SNMP_RETRIES=2         # reintentos por GET
MODBUS_TIMEOUT_S=8     # segundos de espera por lectura Modbus TCP

# --- Retención (en días) en PostgreSQL --------------------------------------
HISTORY_RETENTION_DAYS=7       # ups_chart_history (diagrama: solo últimos 7 días)
METRICS_RETENTION_DAYS=90      # ups_metrics

# --- Pools de conexión ------------------------------------------------------
# Pool principal de GestorDB (HTTP + servicios). 20 alcanza para 150 UPS +
# tráfico web. `max_connections` en postgresql.conf debe ser >= 40.
DB_POOL_MIN=4
DB_POOL_MAX=50      # >=50 recomendado para ~150 dispositivos

# Pool dedicado de pg_metrics (escrituras de series de tiempo).
METRICS_POOL_MAX=10

# --- Admin inicial ----------------------------------------------------------
# Solo se aplica si la tabla `users` está vacía. CAMBIA LA CONTRASEÑA.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=cambiame_al_primer_login
ADMIN_EMAIL=admin@lbs.com.mx

# --- PostgreSQL -------------------------------------------------------------
DB_USER=guia_app
DB_PASSWORD=cambiame123
DB_NAME=guia_instalacion
# Puerto expuesto en el host (cambiar si choca con otra instancia).
DB_EXTERNAL_PORT=5432

# Si quieres apuntar a una BD externa en vez de levantar la del compose,
# descomenta y rellena. Si lo dejas comentado, el portal usa la BD del
# servicio `db`.
# DATABASE_URL=postgresql://guia_app:cambiame123@host.lbs.lan:5432/guia_instalacion

# --- Imagen Docker ----------------------------------------------------------
# Para usar una imagen pre-construida en lugar de `build .`, descomenta:
# PORTAL_IMAGE=registry.example.com/lbs/portal:v1.0.0

# --- Cloudflare Tunnel ------------------------------------------------------
# 1. https://one.dash.cloudflare.com → Zero Trust → Networks → Tunnels
# 2. Crea un tunnel y pega aquí su token
# 3. En el tunnel agrega un Public Hostname → http://localhost:5000
# 4. Levanta con: docker compose --profile tunnel up -d
CLOUDFLARE_TUNNEL_TOKEN=
