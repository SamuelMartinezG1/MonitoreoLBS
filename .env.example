# ============================================================
#  UPS Monitoring Service — Variables de entorno
# ============================================================
# Copia este archivo a `.env` y ajusta los valores.

# --- App ---
SECRET_KEY=cambia-esto-por-una-clave-de-32-caracteres
APP_PORT=5000
LOG_LEVEL=INFO
POLL_INTERVAL=2

# Retención (en días) en PostgreSQL
HISTORY_RETENTION_DAYS=30      # ups_chart_history
METRICS_RETENTION_DAYS=90      # ups_metrics (series de tiempo)

# --- PostgreSQL ---
DB_USER=guia_app
DB_PASSWORD=cambiame123
DB_NAME=guia_instalacion
# DSN completo (lo arma el compose si dejas las variables anteriores)
# DATABASE_URL=postgresql://guia_app:cambiame123@127.0.0.1:5432/guia_instalacion

# --- Cloudflare Tunnel ---
# 1. https://one.dash.cloudflare.com/  →  Zero Trust → Networks → Tunnels
# 2. Crea un tunnel y pega aquí su token
# 3. En el tunnel agrega un Public Hostname  →  http://localhost:5000
CLOUDFLARE_TUNNEL_TOKEN=
